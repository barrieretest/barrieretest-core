{
  "name": "@barrieretest/core",
  "version": "0.6.0",
  "description": "Open-source core for single-page accessibility audits",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "barrieretest": "./dist/cli/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "debug:cli": "npm run build && node --inspect-brk ./dist/cli/bin.js",
    "prepack": "npm run build",
    "test": "bun test --path-ignore-patterns='**/audit-integration.test.ts' && bun test src/audit-integration.test.ts",
    "test:unit": "bun test --path-ignore-patterns='**/audit-integration.test.ts'",
    "test:integration": "bun test src/audit-integration.test.ts",
    "test:watch": "bun test --path-ignore-patterns='**/audit-integration.test.ts' --watch",
    "lint": "biome format --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axe-core": "^4.10.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "latest",
    "@types/pa11y": "^5.3.7",
    "pa11y": "^9.0.1",
    "puppeteer": "~24.25.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "pa11y": "^9.0.1",
    "playwright": "^1.40.0",
    "puppeteer": ">=20.0.0"
  },
  "peerDependenciesMeta": {
    "pa11y": {
      "optional": true
    },
    "playwright": {
      "optional": true
    },
    "puppeteer": {
      "optional": true
    }
  },
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "audit",
    "pa11y",
    "axe-core"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://barrieretest.at",
  "bugs": {
    "url": "https://github.com/barrieretest/barrieretest-core/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/barrieretest/barrieretest-core"
  }
}
